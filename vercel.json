{
    "framework": "nextjs",
    "installCommand": "npm install",
    "buildCommand": "npm run build",
    "outputDirectory": ".next",
    "regions": [
        "sin1"
    ],
    "crons": [
        {
            "path": "/api/cron/overdue-bills",
            "schedule": "0 23 * * *"
        },
        {
            "path": "/api/cron/plan-expiry",
            "schedule": "0 0 * * *"
        },
        {
            "path": "/api/cron/send-reminders",
            "schedule": "0 1 * * *"
        },
        {
            "path": "/api/cron/zns-contract-expiry",
            "schedule": "0 1 * * *"
        }
    ]
}