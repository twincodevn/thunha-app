generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(cuid())
  email             String?            @unique
  phone             String?            @unique
  password          String
  name              String
  avatar            String?
  plan              UserPlan           @default(FREE)
  planExpiresAt     DateTime?
  maxRooms          Int                @default(3)
  emailVerified     DateTime?
  phoneVerified     DateTime?
  resetToken        String?
  resetTokenExpiry  DateTime?
  bankName          String?
  bankAccountNumber String?
  bankAccountName   String?
  createdIp         String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  contractTemplates ContractTemplate[]
  properties        Property[]
  tenants           Tenant[]
  notifications   Notification[]

  @@index([email])
  @@index([phone])
  @@index([resetToken])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   // INCIDENT, BILL, SYSTEM
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}


model Property {
  id              String     @id @default(cuid())
  userId          String
  name            String
  address         String
  city            String?
  notes           String?
  electricityRate Float      @default(0)
  waterRate       Float      @default(25000)
  services        Json?
  lat             Float?
  lng             Float?
  images          String[]   @default([])
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  incidents       Incident[]
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  rooms           Room[]

  @@index([userId])
}

model Room {
  id            String         @id @default(cuid())
  propertyId    String
  roomNumber    String
  floor         Int            @default(1)
  area          Float?
  baseRent      Float
  deposit       Float?
  status        RoomStatus     @default(VACANT)
  notes         String?
  images        String[]       @default([])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  assets        Asset[]
  meterReadings MeterReading[]
  property      Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  roomTenants   RoomTenant[]

  @@unique([propertyId, roomNumber])
  @@index([propertyId])
}

model Tenant {
  id          String       @id @default(cuid())
  userId      String
  name        String
  phone       String
  email       String?
  idNumber    String?
  address     String?
  idPhoto     String?
  avatar      String?
  dateOfBirth DateTime?
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  username    String?      @unique
  password    String?
  lastLogin   DateTime?
  roomTenants RoomTenant[]
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([phone])
  @@index([username])
}

model RoomTenant {
  id          String     @id @default(cuid())
  roomId      String
  tenantId    String
  startDate   DateTime
  endDate     DateTime?
  contractUrl String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  bills       Bill[]
  contracts   Contract[]
  deposits    Deposit[]
  incidents   Incident[]
  room        Room       @relation(fields: [roomId], references: [id], onDelete: Cascade)
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([tenantId])
  @@index([isActive])
}

model MeterReading {
  id                 String   @id @default(cuid())
  roomId             String
  month              Int
  year               Int
  electricityPrev    Float    @default(0)
  electricityCurrent Float    @default(0)
  electricityUsage   Float    @default(0)
  waterPrev          Float    @default(0)
  waterCurrent       Float    @default(0)
  waterUsage         Float    @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  bill               Bill?
  room               Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, month, year])
  @@index([roomId])
}

model Bill {
  id                String        @id @default(cuid())
  roomTenantId      String
  meterReadingId    String?       @unique
  month             Int
  year              Int
  baseRent          Float
  electricityAmount Float         @default(0)
  electricityUsage  Float         @default(0)
  waterAmount       Float         @default(0)
  waterUsage        Float         @default(0)
  extraCharges      Json?
  discount          Float         @default(0)
  total             Float
  dueDate           DateTime
  status            BillStatus    @default(DRAFT)
  notes             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  meterReading      MeterReading? @relation(fields: [meterReadingId], references: [id])
  roomTenant        RoomTenant    @relation(fields: [roomTenantId], references: [id], onDelete: Cascade)
  invoice           Invoice?
  payments          Payment[]

  @@unique([roomTenantId, month, year])
  @@index([status])
  @@index([dueDate])
}

model Invoice {
  id        String    @id @default(cuid())
  billId    String    @unique
  token     String    @unique @default(cuid())
  pdfUrl    String?
  sentVia   String?
  sentAt    DateTime?
  viewedAt  DateTime?
  createdAt DateTime  @default(now())
  bill      Bill      @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([token])
}

model Payment {
  id            String        @id @default(cuid())
  billId        String
  amount        Float
  method        PaymentMethod
  transactionId String?
  note          String?
  paidAt        DateTime      @default(now())
  bill          Bill          @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([billId])
  @@index([transactionId])
}

model Incident {
  id           String           @id @default(cuid())
  propertyId   String
  roomTenantId String?
  title        String
  description  String
  images       String
  status       IncidentStatus   @default(OPEN)
  priority     IncidentPriority @default(MEDIUM)
  cost         Float?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  property     Property         @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  roomTenant   RoomTenant?      @relation(fields: [roomTenantId], references: [id])

  @@index([propertyId])
  @@index([status])
}

model Asset {
  id           String      @id @default(cuid())
  roomId       String
  name         String
  code         String?
  status       AssetStatus @default(GOOD)
  value        Float?
  notes        String?
  images       String
  purchaseDate DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  room         Room        @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
}

model ContractTemplate {
  id        String     @id @default(cuid())
  userId    String
  name      String
  content   String
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  contracts Contract[]
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Contract {
  id                String            @id @default(cuid())
  roomTenantId      String
  templateId        String?
  content           String
  status            ContractStatus    @default(DRAFT)
  landlordSignature String?
  tenantSignature   String?
  signatureImage    String? // Base64 or URL of signature image
  signedAt          DateTime?
  startDate         DateTime
  endDate           DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  roomTenant        RoomTenant        @relation(fields: [roomTenantId], references: [id], onDelete: Cascade)
  template          ContractTemplate? @relation(fields: [templateId], references: [id])

  @@index([roomTenantId])
  @@index([status])
}

enum UserPlan {
  FREE
  BASIC
  PRO
  BUSINESS
}

enum RoomStatus {
  VACANT
  OCCUPIED
  MAINTENANCE
  COMING_SOON
}

enum BillStatus {
  DRAFT
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  VNPAY
  MOMO
}

enum IncidentStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CANCELLED
}

enum IncidentPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum AssetStatus {
  GOOD
  REPAIR
  BROKEN
  LOST
}

enum ContractStatus {
  DRAFT
  SENT
  SIGNED
  EXPIRED
  TERMINATED
}

model Deposit {
  id           String     @id @default(cuid())
  roomTenantId String
  amount       Float
  type         String     // RECEIVED, RETURNED, DEDUCTED
  reason       String?
  date         DateTime   @default(now())
  createdAt    DateTime   @default(now())
  roomTenant   RoomTenant @relation(fields: [roomTenantId], references: [id], onDelete: Cascade)

  @@index([roomTenantId])
}
