generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(cuid())
  email             String?            @unique
  phone             String?            @unique
  password          String
  name              String
  avatar            String?
  plan              UserPlan           @default(FREE)
  planExpiresAt     DateTime?
  maxRooms          Int                @default(3)
  emailVerified     DateTime?
  phoneVerified     DateTime?
  resetToken        String?
  resetTokenExpiry  DateTime?
  bankName          String?
  bankAccountNumber String?
  bankAccountName   String?
  createdIp         String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  zaloOaAccessToken  String?           // Zalo OA access token
  zaloOaRefreshToken String?           // Zalo OA refresh token
  zaloOaTokenExpiry  DateTime?         // Token expiry time
  zaloOaId           String?           // OA ID from Zalo developer portal
  contractTemplates   ContractTemplate[]
  properties          Property[]
  tenants             Tenant[]
  notifications       Notification[]
  announcements       Announcement[]
  subscriptionOrders  SubscriptionOrder[]

  @@index([email])
  @@index([phone])
  @@index([resetToken])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String?
  tenantId    String?
  title       String
  message     String
  type        String   // INCIDENT, BILL, SYSTEM, ANNOUNCEMENT
  link        String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@index([isRead])
}

model Announcement {
  id          String    @id @default(cuid())
  propertyId  String
  userId      String    // The landlord who created it
  title       String
  content     String    @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  property    Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([userId])
}


model Property {
  id              String     @id @default(cuid())
  userId          String
  name            String
  address         String
  city            String?
  notes           String?
  electricityRate Float      @default(0)
  waterRate       Float      @default(25000)
  lateFee         Float?     @default(0)
  lateFeeType     String     @default("FIXED") // "FIXED" or "PERCENTAGE"
  services        Json?
  lat             Float?
  lng             Float?
  images          String[]   @default([])
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  incidents       Incident[]
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  rooms           Room[]
  feedbacks       TenantFeedback[]
  announcements   Announcement[]

  @@index([userId])
}

model Room {
  id            String         @id @default(cuid())
  propertyId    String
  roomNumber    String
  floor         Int            @default(1)
  area          Float?
  baseRent      Float
  deposit       Float?
  status        RoomStatus     @default(VACANT)
  notes         String?
  images        String[]       @default([])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  assets        Asset[]
  meterReadings MeterReading[]
  property      Property       @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  roomTenants   RoomTenant[]


  @@unique([propertyId, roomNumber])
  @@index([propertyId])
}

model Tenant {
  id          String       @id @default(cuid())
  userId      String
  name        String
  phone       String
  email       String?
  idNumber    String?
  address     String?
  idPhoto     String?
  avatar      String?
  dateOfBirth DateTime?
  notes          String?
  creditScore    Int          @default(600)
  paymentHistory Json?
  zaloUserId     String?              // Zalo user ID (set when tenant messages OA)
  zaloPhone      String?              // Normalized phone for ZNS (84xxxxxxxxx format)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  username       String?      @unique
  password       String?
  lastLogin      DateTime?
  roomTenants    RoomTenant[]
  feedbacks      TenantFeedback[]
  notifications  Notification[]
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([phone])
  @@index([username])
}

model RoomTenant {
  id          String     @id @default(cuid())
  roomId      String
  tenantId    String
  startDate   DateTime
  endDate     DateTime?
  contractUrl String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  bills       Bill[]
  contracts   Contract[]
  deposits    Deposit[]
  incidents   Incident[]
  room        Room       @relation(fields: [roomId], references: [id], onDelete: Restrict)
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([roomId])
  @@index([tenantId])
  @@index([isActive])
}

model MeterReading {
  id                 String   @id @default(cuid())
  roomId             String
  month              Int
  year               Int
  electricityPrev    Float    @default(0)
  electricityCurrent Float    @default(0)
  electricityUsage   Float    @default(0)
  waterPrev          Float    @default(0)
  waterCurrent       Float    @default(0)
  waterUsage         Float    @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  bill               Bill?
  room               Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, month, year])
  @@index([roomId])
}

model Bill {
  id                String        @id @default(cuid())
  roomTenantId      String
  meterReadingId    String?       @unique
  month             Int
  year              Int
  baseRent          Float
  electricityAmount Float         @default(0)
  electricityUsage  Float         @default(0)
  waterAmount       Float         @default(0)
  waterUsage        Float         @default(0)
  extraCharges      Json?
  discount          Float         @default(0)
  total             Float
  dueDate           DateTime
  status            BillStatus    @default(DRAFT)
  notes             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  meterReading      MeterReading? @relation(fields: [meterReadingId], references: [id])
  roomTenant        RoomTenant    @relation(fields: [roomTenantId], references: [id], onDelete: Restrict)
  invoice           Invoice?
  payments          Payment[]

  @@unique([roomTenantId, month, year])
  @@index([status])
  @@index([dueDate])
}

model Invoice {
  id        String    @id @default(cuid())
  billId    String    @unique
  token     String    @unique @default(cuid())
  pdfUrl    String?
  sentVia   String?
  sentAt    DateTime?
  viewedAt  DateTime?
  createdAt DateTime  @default(now())
  bill      Bill      @relation(fields: [billId], references: [id], onDelete: Restrict)

  @@index([token])
}

model Payment {
  id            String        @id @default(cuid())
  billId        String
  amount        Float
  method        PaymentMethod
  transactionId String?
  note          String?
  paidAt        DateTime      @default(now())
  bill          Bill          @relation(fields: [billId], references: [id], onDelete: Restrict)

  @@index([billId])
  @@index([transactionId])
}

model Incident {
  id           String           @id @default(cuid())
  propertyId   String
  roomTenantId String?
  title        String
  description  String
  images       String
  status       IncidentStatus   @default(OPEN)
  priority     IncidentPriority @default(MEDIUM)
  cost         Float?
  resolvedAt   DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  property     Property         @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  roomTenant   RoomTenant?      @relation(fields: [roomTenantId], references: [id])

  @@index([propertyId])
  @@index([status])
}

model Asset {
  id           String      @id @default(cuid())
  roomId       String
  name         String
  code         String?
  status       AssetStatus @default(GOOD)
  value        Float?
  notes        String?
  images       String
  purchaseDate DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  room         Room        @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
}

model ContractTemplate {
  id        String     @id @default(cuid())
  userId    String
  name      String
  content   String
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  contracts Contract[]
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Contract {
  id                String            @id @default(cuid())
  roomTenantId      String
  templateId        String?
  content           String
  status            ContractStatus    @default(DRAFT)
  landlordSignature String?
  tenantSignature   String?
  signatureImage    String? // Base64 or URL of signature image
  signedAt          DateTime?
  startDate         DateTime
  endDate           DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  roomTenant        RoomTenant        @relation(fields: [roomTenantId], references: [id], onDelete: Cascade)
  template          ContractTemplate? @relation(fields: [templateId], references: [id])

  @@index([roomTenantId])
  @@index([status])
}

enum UserPlan {
  FREE
  BASIC
  PRO
  BUSINESS
}

enum RoomStatus {
  VACANT
  OCCUPIED
  MAINTENANCE
  COMING_SOON
}

enum BillStatus {
  DRAFT
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  VNPAY
  MOMO
}

enum IncidentStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CANCELLED
}

enum IncidentPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum AssetStatus {
  GOOD
  REPAIR
  BROKEN
  LOST
}

enum ContractStatus {
  DRAFT
  SENT
  SIGNED
  EXPIRED
  TERMINATED
}

model SubscriptionOrder {
  id            String   @id @default(cuid())
  userId        String
  plan          UserPlan
  amount        Float
  status        String   @default("PENDING") // PENDING | PAID | FAILED
  vnpayTxnRef   String?  @unique
  vnpayTxnNo    String?
  paidAt        DateTime?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([vnpayTxnRef])
}

model Deposit {
  id           String     @id @default(cuid())
  roomTenantId String
  amount       Float
  type         String     // RECEIVED, RETURNED, DEDUCTED
  reason       String?
  date         DateTime   @default(now())
  createdAt    DateTime   @default(now())
  roomTenant   RoomTenant @relation(fields: [roomTenantId], references: [id], onDelete: Cascade)

  @@index([roomTenantId])
}

model TenantFeedback {
  id           String      @id @default(cuid())
  tenantId     String
  propertyId   String
  rating       Int         @default(5) // 1 to 5 stars
  comment      String?     @db.Text
  createdAt    DateTime    @default(now())

  tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property     Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([tenantId])
}
